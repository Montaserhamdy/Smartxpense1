# Server
NODE_ENV=production
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (Supabase — free tier PostgreSQL)
# Sign up at https://supabase.com, create a project, then copy these from
# Project Settings > API and add them to Railway variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Optional: direct Postgres access (Project Settings > Database > Connection string)
DATABASE_URL=postgresql://user:password@host/database

# Auth (wired up in Phase 2 — placeholders reserved now so .env shape is stable)
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
