# Server
NODE_ENV=production
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartxpense?schema=public"

# Auth
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=replace-me
SMTP_PASS=replace-me
EMAIL_FROM="no-reply@smartxpense.local"
