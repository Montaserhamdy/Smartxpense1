# Server
NODE_ENV=production
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartxpense?schema=public"

# Auth (wired up in Phase 2 — placeholders reserved now so .env shape is stable)
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
